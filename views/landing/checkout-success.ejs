<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #7c3aed;
            --primary-light: #a855f7;
            --success: #22c55e;
            --bg-dark: #0f172a;
            --bg-card: rgba(30, 41, 59, 0.8);
            --text-primary: #f1f5f9;
            --text-secondary: #94a3b8;
            --border-color: rgba(148, 163, 184, 0.15);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-dark);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .success-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 48px 40px;
            max-width: 500px;
            width: 100%;
            text-align: center;
        }

        .success-icon {
            width: 90px;
            height: 90px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--success), #16a34a);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            font-size: 42px;
            color: #fff;
            animation: successBounce 0.6s ease;
        }

        @keyframes successBounce {
            0% {
                transform: scale(0);
            }

            50% {
                transform: scale(1.2);
            }

            100% {
                transform: scale(1);
            }
        }

        .success-title {
            font-size: 26px;
            font-weight: 700;
            color: var(--success);
            margin-bottom: 8px;
        }

        .success-desc {
            color: var(--text-secondary);
            margin-bottom: 28px;
            font-size: 15px;
        }

        .order-info {
            background: rgba(124, 58, 237, 0.1);
            border: 1px solid rgba(124, 58, 237, 0.2);
            border-radius: 12px;
            padding: 20px;
            text-align: left;
            margin-bottom: 24px;
        }

        .order-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            font-size: 14px;
        }

        .order-row.total {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            margin-top: 8px;
            padding-top: 16px;
            font-weight: 700;
            font-size: 16px;
        }

        .order-row.total .value {
            color: var(--primary-light);
            font-size: 20px;
        }

        .label {
            color: var(--text-secondary);
        }

        .value {
            font-weight: 600;
        }

        .btn-zalo {
            display: block;
            width: 100%;
            padding: 18px 32px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, #0068ff, #0099ff);
            color: #fff;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            text-align: center;
            text-decoration: none;
            margin-bottom: 12px;
            box-shadow: 0 4px 20px rgba(0, 104, 255, 0.4);
        }

        .btn-zalo:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(0, 104, 255, 0.5);
            color: #fff;
        }

        .zalo-hint {
            font-size: 13px;
            color: var(--text-secondary);
            margin-bottom: 20px;
        }

        .home-link {
            color: var(--text-secondary);
            font-size: 14px;
            text-decoration: none;
        }

        .home-link:hover {
            color: var(--text-primary);
        }
    </style>
</head>

<body>
    <div class="success-card">
        <div class="success-icon">
            <i class="bi bi-check-lg"></i>
        </div>
        <h1 class="success-title">Thanh toán thành công!</h1>
        <p class="success-desc">
            Đơn hàng <strong>
                <%= order.order_code %>
            </strong> đã được xác nhận.<br>
            Cảm ơn bạn đã mua hàng tại <strong>
                <%= settings.brand_name || 'Tobi Store' %>
            </strong>!
        </p>

        <div class="order-info">
            <div class="order-row">
                <span class="label">Sản phẩm</span>
                <span class="value">
                    <%= order.product_name %>
                </span>
            </div>
            <div class="order-row total">
                <span class="label">Đã thanh toán</span>
                <span class="value">
                    <%= Number(order.actual_price).toLocaleString('vi-VN') %>đ
                </span>
            </div>
        </div>

        <a href="<%= settings.zalo_link || '#' %>" target="_blank" rel="noopener" class="btn-zalo">
            <i class="bi bi-chat-dots-fill" style="margin-right:8px;"></i> Nhắn Zalo để nhận tài khoản
        </a>
        <p class="zalo-hint">
            <i class="bi bi-info-circle"></i> Gửi mã đơn hàng <strong>
                <%= order.order_code %>
            </strong> qua Zalo để nhận tài khoản nhanh nhất
        </p>

        <a href="/" class="home-link">
            <i class="bi bi-house"></i> Về trang chủ
        </a>
    </div>
</body>

</html>